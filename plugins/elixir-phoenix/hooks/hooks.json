{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.ex)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-elixir.sh",
            "timeout": 30,
            "statusMessage": "Formatting Elixir..."
          },
          {
            "type": "command",
            "if": "Edit(*.exs)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-elixir.sh",
            "timeout": 30,
            "statusMessage": "Formatting Elixir..."
          },
          {
            "type": "command",
            "if": "Edit(*.ex)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/iron-law-verifier.sh",
            "timeout": 15,
            "statusMessage": "Verifying Iron Laws..."
          },
          {
            "type": "command",
            "if": "Edit(*.exs)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/iron-law-verifier.sh",
            "timeout": 15,
            "statusMessage": "Verifying Iron Laws..."
          },
          {
            "type": "command",
            "if": "Edit(*.ex)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/debug-statement-warning.sh",
            "timeout": 15,
            "statusMessage": "Checking for debug statements..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "if": "Write(*.ex)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-elixir.sh",
            "timeout": 30,
            "statusMessage": "Formatting Elixir..."
          },
          {
            "type": "command",
            "if": "Write(*.exs)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-elixir.sh",
            "timeout": 30,
            "statusMessage": "Formatting Elixir..."
          },
          {
            "type": "command",
            "if": "Write(*.ex)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/iron-law-verifier.sh",
            "timeout": 15,
            "statusMessage": "Verifying Iron Laws..."
          },
          {
            "type": "command",
            "if": "Write(*.exs)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/iron-law-verifier.sh",
            "timeout": 15,
            "statusMessage": "Verifying Iron Laws..."
          },
          {
            "type": "command",
            "if": "Write(*.ex)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/debug-statement-warning.sh",
            "timeout": 15,
            "statusMessage": "Checking for debug statements..."
          },
          {
            "type": "command",
            "if": "Write(*plan.md)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/plan-stop-reminder.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.ex)|Edit(*.exs)|Edit(*.heex)|Edit(*.eex)|Edit(*.leex)|Write(*.ex)|Write(*.exs)|Write(*.heex)|Write(*.eex)|Write(*.leex)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/security-reminder.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/log-progress.sh",
            "timeout": 15,
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/block-dangerous-ops.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "if": "Bash(*mix deps.*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/deps-audit-gate.sh",
            "timeout": 5,
            "statusMessage": "Tiered deps audit..."
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(*mix*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/elixir-failure-hints.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*mix*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/error-critic.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/inject-iron-laws.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/setup-dirs.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/detect-tidewave.sh",
            "timeout": 30,
            "statusMessage": "Detecting Tidewave...",
            "async": true
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-scratchpad.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-resume.sh",
            "timeout": 30,
            "statusMessage": "Checking for resumable work..."
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-branch-freshness.sh",
            "timeout": 30,
            "async": true
          },
          {
            "type": "command",
            "command": "echo",
            "args": ["Elixir/Phoenix plugin loaded — describe your task and I'll suggest the right workflow"]
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/precompact-rules.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/postcompact-verify.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/stop-failure-log.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-pending-plans.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
